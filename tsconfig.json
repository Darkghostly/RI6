{
  "compilerOptions": {
    "target": "ES5",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "out/",
    "rootDir": "./src",
    "moduleResolution": "node",
    "noImplicitAny": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*"
  ]
}